# 1. Lightweight Node image
FROM node:20-slim

# 2. Install git and immediately clean the apt cache to keep the image tiny
RUN apt-get update && \
    apt-get install -y git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /home/app

# 3. Copy ONLY package files first to leverage Docker layer caching
COPY package*.json ./

# 4. Install dependencies (Docker skips this step in future builds if package.json hasn't changed)
RUN npm install

# 5. NOW copy your scripts
COPY main.sh .
COPY script.js .

# 6. Make them executable
RUN chmod +x main.sh script.js

ENTRYPOINT [ "/home/app/main.sh" ]